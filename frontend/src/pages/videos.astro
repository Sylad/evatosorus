---
import CodexLayout from '../layouts/CodexLayout.astro';
import { YOUTUBE_CHANNELS, LANGUAGE_LABELS, ACCENT_HEX } from '../data/youtube-channels';
---
<CodexLayout
  title="Vidéos YouTube — Evatosorus"
  description={`${YOUTUBE_CHANNELS.length} chaînes YouTube paléontologie sélectionnées : PBS Eons, DirtyBiology, Le Sense of Wonder...`}
  active="videos"
>
  <header class="videos-header">
    <p class="codex-eyebrow">vidéos</p>
    <h1>Pour aller plus loin sur YouTube</h1>
    <p class="codex-lede">
      {YOUTUBE_CHANNELS.length} chaînes sélectionnées pour ado/adulte passionné — mix
      français et anglais. Toutes appliquent une rigueur scientifique : pas de
      sensationnel, pas de raptor inflated, pas de "le T-Rex avait des plumes
      tout du long". Le tri a déjà été fait.
    </p>
  </header>

  <div class="channels-grid">
    {YOUTUBE_CHANNELS.map((c) => {
      const initials = c.name.split(/\s+/).slice(0, 2).map((w) => w[0]).join('');
      return (
        <a href={c.url} target="_blank" rel="noopener noreferrer" class="channel-card" style={`--accent:${ACCENT_HEX[c.accent]}`}>
          <div class="channel-head">
            <div class="channel-avatar" aria-hidden="true">{initials}</div>
            <div class="channel-id">
              <h2>{c.name}</h2>
              <p class="handle">{c.handle}</p>
            </div>
            <span class="channel-lang">{LANGUAGE_LABELS[c.language]}</span>
          </div>

          <div class="channel-stats">
            <span class="stat-subs">▶ {c.subscribers} abonnés</span>
            <div class="topics">
              {c.topics.map((t) => <span class="topic">{t}</span>)}
            </div>
          </div>

          <p class="channel-blurb">{c.blurb}</p>

          {c.featured && (
            <div class="channel-featured">
              <span class="featured-label">à voir</span>
              <span class="featured-title">{c.featured.title}</span>
            </div>
          )}

          <div class="channel-cta">
            <span>Ouvrir la chaîne</span>
            <span class="arrow">↗</span>
          </div>
        </a>
      );
    })}
  </div>

  <p class="videos-note">
    Pas de bookmarks YouTube embarqués pour rester léger côté Cloudflare. Chaque
    card est un lien externe — clique, ça ouvre dans un onglet à part.
  </p>

  <style>
    .videos-header {
      margin-bottom: 2.5rem;
    }
    .codex-eyebrow {
      font-family: var(--font-display);
      font-size: 0.72rem;
      letter-spacing: 0.32em;
      color: var(--color-evato-amber);
      text-transform: uppercase;
      margin: 0 0 0.4rem;
    }
    .videos-header h1 {
      font-size: 2.2rem;
      margin: 0 0 0.5rem;
    }
    .codex-lede {
      max-width: 65ch;
      color: var(--color-evato-bone-muted);
      font-size: 1.05rem;
      line-height: 1.6;
    }
    .channels-grid {
      display: grid;
      grid-template-columns: repeat(auto-fill, minmax(340px, 1fr));
      gap: 1.4rem;
      margin-bottom: 2rem;
    }
    .channel-card {
      display: flex;
      flex-direction: column;
      gap: 0.8rem;
      padding: 1.4rem 1.5rem;
      background: linear-gradient(160deg, rgba(26, 18, 10, 0.85), rgba(13, 10, 6, 0.7));
      border: 1px solid color-mix(in srgb, var(--accent) 25%, rgba(212, 165, 94, 0.18));
      border-radius: 8px;
      text-decoration: none;
      color: inherit;
      transition: transform 220ms ease, border-color 220ms ease, box-shadow 220ms ease;
      position: relative;
      overflow: hidden;
    }
    .channel-card::before {
      content: '';
      position: absolute;
      inset: -2px;
      background: radial-gradient(ellipse at 30% 0%, color-mix(in srgb, var(--accent) 15%, transparent), transparent 60%);
      pointer-events: none;
    }
    .channel-card:hover {
      transform: translateY(-3px);
      border-color: var(--accent);
      box-shadow: 0 16px 32px -16px color-mix(in srgb, var(--accent) 60%, transparent);
    }
    .channel-head {
      display: flex;
      align-items: center;
      gap: 0.9rem;
      position: relative;
      z-index: 1;
    }
    .channel-avatar {
      width: 56px;
      height: 56px;
      flex-shrink: 0;
      border-radius: 50%;
      display: grid;
      place-items: center;
      font-family: var(--font-display);
      font-size: 1.3rem;
      font-weight: 700;
      letter-spacing: 0.04em;
      background: linear-gradient(135deg, color-mix(in srgb, var(--accent) 70%, #1a120a), color-mix(in srgb, var(--accent) 35%, #0d0a06));
      color: #0d0a06;
      border: 1px solid var(--accent);
    }
    .channel-id { flex: 1; min-width: 0; }
    .channel-id h2 {
      font-family: var(--font-display);
      font-size: 1.1rem;
      letter-spacing: 0.04em;
      margin: 0;
      color: var(--color-evato-amber-bright);
      line-height: 1.2;
    }
    .handle {
      font-style: italic;
      font-size: 0.78rem;
      color: var(--color-evato-bone-muted);
      margin: 0.15rem 0 0;
    }
    .channel-lang {
      font-family: var(--font-display);
      font-size: 0.62rem;
      letter-spacing: 0.22em;
      text-transform: uppercase;
      padding: 0.25rem 0.55rem;
      border-radius: 999px;
      background: rgba(13, 10, 6, 0.7);
      color: var(--accent);
      border: 1px solid var(--accent);
    }
    .channel-stats {
      display: flex;
      flex-wrap: wrap;
      align-items: center;
      gap: 0.5rem;
      position: relative;
      z-index: 1;
    }
    .stat-subs {
      font-family: var(--font-display);
      font-size: 0.78rem;
      letter-spacing: 0.18em;
      color: var(--accent);
    }
    .topics {
      display: flex;
      gap: 0.3rem;
      flex-wrap: wrap;
    }
    .topic {
      font-size: 0.7rem;
      padding: 0.2rem 0.5rem;
      border-radius: 999px;
      background: rgba(13, 10, 6, 0.6);
      color: var(--color-evato-bone-muted);
      border: 1px solid rgba(212, 165, 94, 0.18);
    }
    .channel-blurb {
      font-size: 0.92rem;
      line-height: 1.55;
      color: var(--color-evato-bone-muted);
      margin: 0;
      position: relative;
      z-index: 1;
    }
    .channel-featured {
      display: flex;
      flex-direction: column;
      gap: 0.2rem;
      padding: 0.7rem 0.9rem;
      background: rgba(212, 165, 94, 0.05);
      border-left: 2px solid var(--accent);
      position: relative;
      z-index: 1;
    }
    .featured-label {
      font-family: var(--font-display);
      font-size: 0.6rem;
      letter-spacing: 0.32em;
      text-transform: uppercase;
      color: var(--accent);
    }
    .featured-title {
      font-style: italic;
      font-size: 0.85rem;
      color: var(--color-evato-bone);
    }
    .channel-cta {
      display: flex;
      justify-content: space-between;
      align-items: center;
      margin-top: auto;
      padding-top: 0.5rem;
      font-family: var(--font-display);
      font-size: 0.72rem;
      letter-spacing: 0.18em;
      text-transform: uppercase;
      color: var(--accent);
      position: relative;
      z-index: 1;
    }
    .arrow {
      transition: transform 220ms ease;
    }
    .channel-card:hover .arrow {
      transform: translate(2px, -2px);
    }
    .videos-note {
      font-size: 0.85rem;
      color: var(--color-evato-bone-muted);
      font-style: italic;
      max-width: 65ch;
    }
  </style>
</CodexLayout>
