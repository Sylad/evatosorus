---
import CodexLayout from '../layouts/CodexLayout.astro';
import PageHero from '../components/PageHero.astro';
import { CodexBrowser } from '../components/CodexBrowser';
import { SPECIES, SPECIES_INDEX, TAXON_GROUP_LABELS, DIET_LABELS, DIET_ICONS } from '../data/species';
import '../components/codex-browser.css';

const taxonGroups = Array.from(new Set(SPECIES.map((s) => s.taxonGroup)))
  .map((id) => ({ id, label: TAXON_GROUP_LABELS[id] ?? id }))
  .sort((a, b) => a.label.localeCompare(b.label, 'fr'));

// Sort : iconic en premier, puis espèces avec paleo-art ou image, puis le reste alphabétique.
// Le user voit les fiches les plus illustrées en premier (1500 entrées dont
// la plupart n'ont pas d'image car PaleoBioDB ne fournit pas de paleo-art).
const sorted = [...SPECIES].sort((a, b) => {
  if (a.iconic && !b.iconic) return -1;
  if (!a.iconic && b.iconic) return 1;
  const aHasImg = !!(a.lifeRestorationUrl || a.imageUrl);
  const bHasImg = !!(b.lifeRestorationUrl || b.imageUrl);
  if (aHasImg && !bHasImg) return -1;
  if (!aHasImg && bHasImg) return 1;
  return a.name.localeCompare(b.name);
});

// Trim les champs serialisés au island React : pour les cards on n'a besoin
// que de ce que le composant Card utilise. Évite d'inliner des champs lourds
// (locations[], blurb, credits, paleobiodbId) qui ne servent qu'à la fiche
// détail. Réduit ~60% du JSON sérialisé dans le HTML.
const trimmed = sorted.map((s) => ({
  id: s.id,
  name: s.name,
  commonName: s.commonName,
  taxonGroup: s.taxonGroup,
  diet: s.diet,
  periodId: s.periodId,
  lengthM: s.lengthM,
  weightKg: s.weightKg,
  iconic: s.iconic,
  imageUrl: s.imageUrl,
  lifeRestorationUrl: s.lifeRestorationUrl,
}));
---
<CodexLayout
  title="Codex — Evatosorus"
  description={`${SPECIES_INDEX.count} espèces du Mésozoïque, filtrables par période, régime et groupe taxonomique.`}
  active="codex"
>
  <PageHero videoSrc="/hero-trex-6.mp4" eyebrow="le codex" title="Toutes les espèces du Mésozoïque" />

  <header class="codex-header">
    <p class="codex-lede">
      {SPECIES_INDEX.count} fiches consultables. Filtre par période, régime ou
      groupe taxonomique pour zoomer sur le tronçon de l'arbre du vivant qui
      t'intéresse — du minuscule Compsognathus jusqu'au titanesque Argentinosaure.
    </p>
  </header>

  <CodexBrowser
    client:only="react"
    species={trimmed}
    taxonGroups={taxonGroups}
    taxonGroupLabels={TAXON_GROUP_LABELS}
    dietLabels={DIET_LABELS}
    dietIcons={DIET_ICONS}
  />

  <noscript>
    <p style="color: var(--color-evato-bone-muted); font-style: italic; padding: 1rem; border: 1px solid rgba(212, 165, 94, 0.18); border-radius: 6px; margin-top: 1rem;">
      Le navigateur du codex (filtres + virtualization de 1500 espèces)
      nécessite JavaScript activé. Si tu préfères l'index statique, va voir
      <a href="/periodes/" style="color: var(--color-evato-amber);">les périodes</a> qui listent les espèces sans JS.
    </p>
  </noscript>

  <style>
    .codex-header {
      margin-bottom: 2rem;
    }
    .codex-lede {
      max-width: 60ch;
      color: var(--color-evato-bone-muted);
      font-size: 1.05rem;
      line-height: 1.6;
    }
  </style>
</CodexLayout>
