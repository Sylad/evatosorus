---
import CodexLayout from '../layouts/CodexLayout.astro';
import PageHero from '../components/PageHero.astro';
import SpeciesCard from '../components/SpeciesCard.astro';
import { CodexFilters } from '../components/CodexFilters';
import { SPECIES, SPECIES_INDEX, TAXON_GROUP_LABELS } from '../data/species';

const taxonGroups = Array.from(new Set(SPECIES.map((s) => s.taxonGroup)))
  .map((id) => ({ id, label: TAXON_GROUP_LABELS[id] ?? id }))
  .sort((a, b) => a.label.localeCompare(b.label, 'fr'));

// Sort : iconic en premier, puis espèces avec paleo-art ou image, puis le reste alphabétique.
// Le user voit les fiches les plus illustrées en premier (1500 entrées dont
// la plupart n'ont pas d'image car PaleoBioDB ne fournit pas de paleo-art).
const sorted = [...SPECIES].sort((a, b) => {
  if (a.iconic && !b.iconic) return -1;
  if (!a.iconic && b.iconic) return 1;
  const aHasImg = !!(a.lifeRestorationUrl || a.imageUrl);
  const bHasImg = !!(b.lifeRestorationUrl || b.imageUrl);
  if (aHasImg && !bHasImg) return -1;
  if (!aHasImg && bHasImg) return 1;
  return a.name.localeCompare(b.name);
});
---
<CodexLayout
  title="Codex — Evatosorus"
  description={`${SPECIES_INDEX.count} espèces du Mésozoïque, filtrables par période, régime et groupe taxonomique.`}
  active="codex"
>
  <PageHero videoSrc="/hero-trex-6.mp4" eyebrow="le codex" title="Toutes les espèces du Mésozoïque" />

  <header class="codex-header">
    <p class="codex-lede">
      {SPECIES_INDEX.count} fiches consultables. Filtre par période, régime ou
      groupe taxonomique pour zoomer sur le tronçon de l'arbre du vivant qui
      t'intéresse — du minuscule Compsognathus jusqu'au titanesque Argentinosaure.
    </p>
  </header>

  <CodexFilters client:load taxonGroups={taxonGroups} />

  <section class="species-grid">
    {sorted.map((s) => (
      <div
        data-species-card
        data-period={s.periodId}
        data-diet={s.diet}
        data-group={s.taxonGroup}
        data-has-image={(s.lifeRestorationUrl || s.imageUrl) ? 'true' : 'false'}
        data-haystack={`${s.name} ${s.commonName ?? ''} ${TAXON_GROUP_LABELS[s.taxonGroup] ?? ''}`}
      >
        <SpeciesCard species={s} />
      </div>
    ))}
  </section>

  <style>
    .codex-header {
      margin-bottom: 2rem;
    }
    .codex-eyebrow {
      font-family: var(--font-display);
      font-size: 0.72rem;
      letter-spacing: 0.32em;
      color: var(--color-evato-amber);
      text-transform: uppercase;
      margin: 0 0 0.4rem;
    }
    .codex-header h1 {
      font-size: 2.2rem;
      color: var(--color-evato-bone);
      margin: 0 0 0.5rem;
    }
    .codex-lede {
      max-width: 60ch;
      color: var(--color-evato-bone-muted);
      font-size: 1.05rem;
      line-height: 1.6;
    }
    .species-grid {
      display: grid;
      grid-template-columns: repeat(auto-fill, minmax(260px, 1fr));
      gap: 1.4rem;
    }
  </style>
</CodexLayout>
