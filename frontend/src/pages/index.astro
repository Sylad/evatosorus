---
import BaseLayout from '../layouts/BaseLayout.astro';
import EvatoLogo from '../components/EvatoLogo.astro';
import EvatoSkull from '../components/EvatoSkull.astro';
import { HeroVideoCycle } from '../components/cinema/HeroVideoCycle';
import { DustField } from '../components/cinema/DustField';
---
<BaseLayout
  title="Evatosorus — Codex Mésozoïque"
  description="Un codex visuel des dinosaures — Trias, Jurassique, Crétacé. 1500+ espèces, paleo-art domaine public."
>
  <!--
    Landing — full-viewport background video. Trois couches :
      1. HeroVideoCycle : 3 MP4 openart.ai (T-Rex jungle/volcan/orage)
         empilés en background fixed, cross-fade toutes les 25s.
      2. DustField : poussière ambre/cendre par-dessus la vidéo.
      3. Voile sombre gradient (main::before) pour la lisibilité du logo.
    Le contenu (logo + tagline + CTAs) flotte au centre sur la vidéo.
  -->
  <HeroVideoCycle client:only="react" />
  <DustField client:only="react" />

  <main class="relative z-10 min-h-screen flex flex-col items-center justify-center text-center px-6 py-12">
    <div class="landing-skull"><EvatoSkull size={300} /></div>
    <EvatoLogo size={500} />

    <p class="mt-8 max-w-2xl text-evato-bone text-lg italic font-body landing-tagline" data-amber-split>
      <span class="font-semibold not-italic">Evatosorus</span> — un codex visuel
      du Mésozoïque, ces 186 millions d'années où des géants ont régné sur la Terre.
    </p>

    <p class="mt-4 max-w-xl text-evato-bone-muted text-base italic font-body landing-sub" data-amber-split>
      « Avant nous, il y a eu eux. »<br/>
      Trias, Jurassique, Crétacé. 1500 espèces, leurs paysages, leurs continents perdus.
    </p>

    <div class="mt-10 flex flex-wrap gap-3 justify-center landing-ctas">
      <a href="/codex/" class="cta cta-amber">Explorer le codex</a>
      <a href="/periodes/" class="cta cta-jade">Voyage temporel</a>
      <a href="/carte/" class="cta cta-rust">Carte paléo-monde</a>
      <a href="/films/" class="cta cta-bone">Films</a>
      <a href="/videos/" class="cta cta-bone">Vidéos YouTube</a>
      <a href="/about/" class="cta cta-ghost">À propos</a>
            </div>
      </div>
    </div>
  </main>
</BaseLayout>

<script is:inline>
  // Wraps each word in [data-amber-split] paragraphs in <span class="amber-word">
  // so the cursor can light up individual words in fossil-amber.
  (() => {
    if (typeof window === 'undefined') return;
    const split = () => {
      const targets = document.querySelectorAll('[data-amber-split]');
      targets.forEach((p) => {
        if (p.dataset.amberSplitDone === '1') return;
        Array.from(p.childNodes).forEach((node) => {
          if (node.nodeType !== Node.TEXT_NODE) return;
          const text = node.textContent ?? '';
          if (!text.trim()) return;
          const frag = document.createDocumentFragment();
          text.split(/(\s+)/).forEach((tok) => {
            if (/^\s+$/.test(tok) || tok === '') {
              frag.appendChild(document.createTextNode(tok));
            } else {
              const span = document.createElement('span');
              span.className = 'amber-word';
              span.textContent = tok;
              frag.appendChild(span);
            }
          });
          p.replaceChild(frag, node);
        });
        p.dataset.amberSplitDone = '1';
      });
    };
    if (document.readyState === 'loading') {
      document.addEventListener('DOMContentLoaded', split);
    } else {
      split();
    }
    document.addEventListener('astro:page-load', split);
  })();
</script>

<style>
  /*
    CTAs landing : retour au design border + texte coloré (préféré par Sylvain),
    mais avec couleurs vraiment saturées et fond opaque pour ressortir sur la
    vidéo de fond.
  */
  .cta {
    padding: 0.7rem 1.3rem;
    border-radius: 4px;
    border: 2px solid;
    font-family: var(--font-display);
    font-size: 0.82rem;
    letter-spacing: 0.2em;
    text-transform: uppercase;
    text-decoration: none;
    background: rgba(13, 10, 6, 0.78);
    backdrop-filter: blur(8px);
    transition: transform 200ms ease, box-shadow 220ms ease, background 220ms ease, color 200ms ease, border-color 200ms ease;
    text-shadow: 0 1px 4px rgba(0, 0, 0, 0.95);
    font-weight: 700;
  }
  .cta:hover {
    transform: translateY(-2px);
    background: rgba(13, 10, 6, 0.92);
  }
  .cta-amber {
    border-color: #ffc879;
    color: #ffc879;
  }
  .cta-amber:hover {
    color: #ffe2a8;
    border-color: #ffe2a8;
    box-shadow: 0 0 0 1px #ffe2a8, 0 0 32px rgba(255, 200, 121, 0.7);
  }
  .cta-jade {
    border-color: #7fd194;
    color: #7fd194;
  }
  .cta-jade:hover {
    color: #a3e8b3;
    border-color: #a3e8b3;
    box-shadow: 0 0 0 1px #a3e8b3, 0 0 28px rgba(127, 209, 148, 0.65);
  }
  .cta-rust {
    border-color: #ff7a4a;
    color: #ff7a4a;
  }
  .cta-rust:hover {
    color: #ff9c70;
    border-color: #ff9c70;
    box-shadow: 0 0 0 1px #ff9c70, 0 0 30px rgba(255, 122, 74, 0.7);
  }
  .cta-bone {
    border-color: #ebd9c5;
    color: #ebd9c5;
  }
  .cta-bone:hover {
    color: #fff5e2;
    border-color: #fff5e2;
    box-shadow: 0 0 0 1px #fff5e2, 0 0 24px rgba(232, 230, 221, 0.55);
  }
  .cta-ghost {
    background: rgba(13, 10, 6, 0.55);
    border-color: rgba(212, 165, 94, 0.45);
    color: #b8a78f;
  }
  .cta-ghost:hover {
    border-color: #ffc879;
    color: #fff5e2;
    box-shadow: 0 0 0 1px #ffc879, 0 0 22px rgba(255, 200, 121, 0.5);
  }

  /* Skull au-dessus du logo */
  .landing-skull {
    margin-bottom: 0.5rem;
    filter: drop-shadow(0 0 12px rgba(255, 234, 0, 0.4));
  }

  /*
    Texte landing en blanc pur + contour noir épais (effet sous-titres TV)
    pour rester ultra-lisible sur les zones lumineuses des MP4. Pas
    d'italique fade : weight 600, contour 4-direction 1px, glow ambre
    derrière.
  */
  .landing-tagline,
  .landing-sub {
    color: #ffffff !important;
    text-shadow:
      -1.5px -1.5px 0 rgba(0, 0, 0, 0.95),
       1.5px -1.5px 0 rgba(0, 0, 0, 0.95),
      -1.5px  1.5px 0 rgba(0, 0, 0, 0.95),
       1.5px  1.5px 0 rgba(0, 0, 0, 0.95),
       0 0 12px rgba(0, 0, 0, 0.85),
       0 0 28px rgba(255, 200, 121, 0.45);
    font-weight: 600;
  }
  .landing-tagline .font-semibold {
    color: #ffe2a8 !important;
    font-weight: 800;
  }
  .landing-sub {
    color: #ffe2a8 !important;
  }

  /*
    Voile combiné : radial dark au centre pour la lisibilité du logo
    (sans cacher complètement la vidéo aux bords) + tint ambre subtle
    pour la cohésion avec la palette globale.
  */
  main::before {
    content: '';
    position: fixed;
    inset: 0;
    z-index: 5;
    pointer-events: none;
    background:
      radial-gradient(ellipse at 50% 50%, rgba(13, 10, 6, 0.7) 0%, rgba(13, 10, 6, 0.4) 45%, rgba(13, 10, 6, 0.2) 80%),
      linear-gradient(to bottom, rgba(13, 10, 6, 0.25) 0%, rgba(13, 10, 6, 0.55) 100%);
  }

  /* Tint ambre par-dessus le voile, très léger (10%), pour la cohésion. */
  main::after {
    content: '';
    position: fixed;
    inset: 0;
    z-index: 6;
    pointer-events: none;
    background:
      radial-gradient(ellipse at 15% 20%, rgba(212, 165, 94, 0.08) 0%, transparent 55%),
      radial-gradient(ellipse at 85% 80%, rgba(199, 81, 49, 0.06) 0%, transparent 55%);
  }

  /* Legacy CSS hero-grid kept only as no-op fallback (composant retiré). */
  .hero-grid { display: contents; }
  .hero-image {
    position: relative;
    margin: 0;
    border-radius: 8px;
    overflow: hidden;
    border: 1px solid rgba(212, 165, 94, 0.35);
    box-shadow:
      0 0 0 1px rgba(13, 10, 6, 0.5),
      0 24px 48px -16px rgba(0, 0, 0, 0.65),
      0 0 60px -20px rgba(212, 165, 94, 0.4);
    aspect-ratio: 4 / 3;
    display: none; /* hero-image n'est plus utilisé sur la landing */
  }
  .hero-image::after {
    content: '';
    position: absolute;
    inset: 0;
    pointer-events: none;
    background:
      radial-gradient(ellipse at 60% 20%, transparent 30%, rgba(13, 10, 6, 0.35) 90%),
      linear-gradient(to bottom, transparent 70%, rgba(13, 10, 6, 0.65) 100%);
  }
  .hero-image img {
    width: 100%;
    height: 100%;
    object-fit: cover;
    display: block;
    filter: saturate(1.05) contrast(1.02);
    animation: hero-breathe 14s ease-in-out infinite;
  }
  @keyframes hero-breathe {
    0%, 100% { transform: scale(1); }
    50%      { transform: scale(1.025); }
  }
  @media (prefers-reduced-motion: reduce) {
    .hero-image img { animation: none; }
  }
  .hero-image figcaption {
    position: absolute;
    bottom: 0.9rem;
    left: 1.1rem;
    right: 1.1rem;
    z-index: 2;
    font-family: var(--font-body);
    font-style: italic;
    font-size: 1rem;
    color: var(--color-evato-bone);
    text-shadow: 0 1px 6px rgba(0, 0, 0, 0.85);
    letter-spacing: 0.02em;
  }

  /* Côté droit : alignement gauche pour matcher la grille, logo gauche aussi. */
  .hero-content {
    display: flex;
    flex-direction: column;
    align-items: flex-start;
    text-align: left;
  }
  @media (max-width: 960px) {
    .hero-content {
      align-items: center;
      text-align: center;
    }
  }
</style>
