---
import BaseLayout from '../layouts/BaseLayout.astro';
import EvatoLogo from '../components/EvatoLogo.astro';
import { CycleBackdrop } from '../components/cinema/CycleBackdrop';
import { DustField } from '../components/cinema/DustField';
---
<BaseLayout
  title="Evatosorus — Codex Mésozoïque"
  description="Un codex visuel des dinosaures — Trias, Jurassique, Crétacé. 1500+ espèces, paleo-art domaine public."
>
  <!--
    Landing — single viewport, pas de scroll forcé. Trois couches :
      1. CycleBackdrop : 3 phases (Trias → Jurassique → Crétacé) qui se
         fondent toutes les 25s sur une boucle de 75s.
      2. DustField : poussière ambre/cendre qui dérive vers le haut,
         évocation cendre volcanique + pollen de fougères primitives.
      3. amber-ambient : 4 radial blobs pour la cohésion globale.
    Le visiteur s'assied, respire, regarde le Mésozoïque défiler.
  -->
  <CycleBackdrop client:only="react" />
  <DustField client:only="react" />
  <div class="amber-ambient" aria-hidden="true"></div>

  <main class="relative z-10 min-h-screen flex items-center px-6 py-12 lg:py-20">
    <div class="hero-grid">
      <!--
        Hero image — paleo-art cinématique du T-Rex iridescent, fougères et
        empreinte de main ocre. Source originale 2304x1728. Le voile gradient
        sur l'image (::after) la fond avec le bg pour qu'elle ne flotte pas.
      -->
      <figure class="hero-image">
        <video
          autoplay
          loop
          muted
          playsinline
          preload="auto"
          poster="/hero-trex.jpg"
          aria-label="Tyrannosaurus rex dans une jungle préhistorique, sous l'orage, avec une empreinte de main ocre sur le flanc"
        >
          <source src="/hero-trex-1.mp4" type="video/mp4" />
          <!-- Fallback statique : le navigateur affiche le poster si la vidéo
               échoue ou est désactivée (Save Data, prefers-reduced-motion). -->
          <img
            src="/hero-trex.jpg"
            alt="Tyrannosaurus rex dans une jungle préhistorique"
          />
        </video>
        <figcaption>« Avant nous, il y a eu eux. »</figcaption>
      </figure>

      <div class="hero-content">
        <EvatoLogo size={460} />

        <p class="mt-7 max-w-xl text-evato-bone text-lg italic font-body landing-tagline" data-amber-split>
          <span class="font-semibold not-italic">Evatosorus</span> — un codex visuel
          du Mésozoïque, ces 186 millions d'années où des géants ont régné sur la Terre.
        </p>

        <p class="mt-4 max-w-xl text-evato-bone-muted text-base italic font-body landing-sub" data-amber-split>
          Trias, Jurassique, Crétacé. 1500 espèces, leurs paysages, leurs continents perdus.
        </p>

        <div class="mt-10 flex flex-wrap gap-3 hero-cta-row">
          <a href="/codex/"
             class="px-5 py-2.5 rounded border border-evato-amber text-evato-amber hover:shadow-glow-amber-strong hover:bg-evato-amber/10 transition backdrop-blur-sm bg-evato-bg/30 font-display tracking-widest text-sm">
            Explorer le codex
          </a>
          <a href="/periodes/"
             class="px-5 py-2.5 rounded border border-evato-jade text-evato-jade hover:shadow-glow-amber hover:bg-evato-jade/10 transition backdrop-blur-sm bg-evato-bg/30 font-display tracking-widest text-sm">
            Voyage temporel
          </a>
          <a href="/carte/"
             class="px-5 py-2.5 rounded border border-evato-rust text-evato-rust hover:shadow-glow-rust hover:bg-evato-rust/10 transition backdrop-blur-sm bg-evato-bg/30 font-display tracking-widest text-sm">
            Carte paléo-monde
          </a>
          <a href="/films/"
             class="px-5 py-2.5 rounded border border-evato-bone-muted text-evato-bone hover:border-evato-bone hover:bg-evato-bone/5 transition backdrop-blur-sm bg-evato-bg/30 font-display tracking-widest text-sm">
            Films
          </a>
          <a href="/about/"
             class="px-5 py-2.5 rounded text-evato-bone-muted hover:text-evato-bone transition-colors backdrop-blur-sm bg-evato-bg/30 font-display tracking-widest text-sm">
            À propos
          </a>
        </div>
      </div>
    </div>
  </main>
</BaseLayout>

<script is:inline>
  // Wraps each word in [data-amber-split] paragraphs in <span class="amber-word">
  // so the cursor can light up individual words in fossil-amber.
  (() => {
    if (typeof window === 'undefined') return;
    const split = () => {
      const targets = document.querySelectorAll('[data-amber-split]');
      targets.forEach((p) => {
        if (p.dataset.amberSplitDone === '1') return;
        Array.from(p.childNodes).forEach((node) => {
          if (node.nodeType !== Node.TEXT_NODE) return;
          const text = node.textContent ?? '';
          if (!text.trim()) return;
          const frag = document.createDocumentFragment();
          text.split(/(\s+)/).forEach((tok) => {
            if (/^\s+$/.test(tok) || tok === '') {
              frag.appendChild(document.createTextNode(tok));
            } else {
              const span = document.createElement('span');
              span.className = 'amber-word';
              span.textContent = tok;
              frag.appendChild(span);
            }
          });
          p.replaceChild(frag, node);
        });
        p.dataset.amberSplitDone = '1';
      });
    };
    if (document.readyState === 'loading') {
      document.addEventListener('DOMContentLoaded', split);
    } else {
      split();
    }
    document.addEventListener('astro:page-load', split);
  })();
</script>

<style>
  /* Voile sombre pour la lisibilité du foreground sur backdrops vifs. */
  main::before {
    content: '';
    position: fixed;
    inset: 0;
    z-index: 5;
    pointer-events: none;
    background: linear-gradient(
      to bottom,
      rgba(13, 10, 6, 0.30) 0%,
      rgba(13, 10, 6, 0.55) 70%,
      rgba(13, 10, 6, 0.80) 100%
    );
  }

  /* Hero grid : image | logo+contenu, ratio 1.1:1 desktop, stack mobile. */
  .hero-grid {
    width: 100%;
    max-width: 1280px;
    margin: 0 auto;
    display: grid;
    grid-template-columns: 1.1fr 1fr;
    gap: clamp(2rem, 4vw, 4rem);
    align-items: center;
  }
  @media (max-width: 960px) {
    .hero-grid {
      grid-template-columns: 1fr;
      gap: 2rem;
    }
  }

  /* Image hero : encadrée d'un trait ambre, glow, voile dégradé en bas
     pour la fondre dans le bg sans rupture nette. */
  .hero-image {
    position: relative;
    margin: 0;
    border-radius: 8px;
    overflow: hidden;
    border: 1px solid rgba(212, 165, 94, 0.35);
    box-shadow:
      0 0 0 1px rgba(13, 10, 6, 0.5),
      0 24px 48px -16px rgba(0, 0, 0, 0.65),
      0 0 60px -20px rgba(212, 165, 94, 0.4);
    aspect-ratio: 4 / 3;
  }
  .hero-image::after {
    content: '';
    position: absolute;
    inset: 0;
    pointer-events: none;
    background:
      radial-gradient(ellipse at 60% 20%, transparent 30%, rgba(13, 10, 6, 0.35) 90%),
      linear-gradient(to bottom, transparent 70%, rgba(13, 10, 6, 0.65) 100%);
  }
  .hero-image img {
    width: 100%;
    height: 100%;
    object-fit: cover;
    display: block;
    filter: saturate(1.05) contrast(1.02);
    animation: hero-breathe 14s ease-in-out infinite;
  }
  @keyframes hero-breathe {
    0%, 100% { transform: scale(1); }
    50%      { transform: scale(1.025); }
  }
  @media (prefers-reduced-motion: reduce) {
    .hero-image img { animation: none; }
  }
  .hero-image figcaption {
    position: absolute;
    bottom: 0.9rem;
    left: 1.1rem;
    right: 1.1rem;
    z-index: 2;
    font-family: var(--font-body);
    font-style: italic;
    font-size: 1rem;
    color: var(--color-evato-bone);
    text-shadow: 0 1px 6px rgba(0, 0, 0, 0.85);
    letter-spacing: 0.02em;
  }

  /* Côté droit : alignement gauche pour matcher la grille, logo gauche aussi. */
  .hero-content {
    display: flex;
    flex-direction: column;
    align-items: flex-start;
    text-align: left;
  }
  @media (max-width: 960px) {
    .hero-content {
      align-items: center;
      text-align: center;
    }
  }
</style>
