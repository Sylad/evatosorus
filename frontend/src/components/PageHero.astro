---
/**
 * Bandeau hero MP4 + overlay (eyebrow + h1) réutilisable sur les pages
 * internes (codex, carte, periodes, films, etc.). Format paysage 21:9
 * desktop, 16:10 mobile. Voile gradient pour la lisibilité du titre.
 */
interface Props {
  videoSrc: string;
  poster?: string;
  eyebrow?: string;
  title: string;
}
const { videoSrc, poster = '/hero-trex.jpg', eyebrow, title } = Astro.props;
---
<div class="page-hero">
  <video autoplay loop muted playsinline preload="auto" poster={poster}>
    <source src={videoSrc} type="video/mp4" />
    <img src={poster} alt="" />
  </video>
  <div class="page-hero-overlay">
    {eyebrow && <p class="page-hero-eyebrow">{eyebrow}</p>}
    <h1>{title}</h1>
  </div>
</div>

<style>
  .page-hero {
    position: relative;
    margin: 0 0 1.5rem;
    border-radius: 8px;
    overflow: hidden;
    border: 1px solid rgba(212, 165, 94, 0.3);
    aspect-ratio: 21 / 9;
    background: #0d0a06;
    box-shadow: 0 18px 36px -16px rgba(0, 0, 0, 0.7);
  }
  .page-hero video {
    width: 100%;
    height: 100%;
    object-fit: cover;
    display: block;
    filter: saturate(1.05);
  }
  .page-hero-overlay {
    position: absolute;
    inset: 0;
    display: flex;
    flex-direction: column;
    justify-content: flex-end;
    padding: 2rem 2.5rem;
    background: linear-gradient(
      to top,
      rgba(13, 10, 6, 0.85) 0%,
      rgba(13, 10, 6, 0.5) 40%,
      rgba(13, 10, 6, 0.05) 70%,
      rgba(13, 10, 6, 0.4) 100%
    );
  }
  .page-hero-eyebrow {
    font-family: var(--font-display);
    font-size: 0.72rem;
    letter-spacing: 0.32em;
    color: var(--color-evato-amber);
    text-transform: uppercase;
    margin: 0 0 0.3rem;
  }
  .page-hero-overlay h1 {
    font-size: 2.4rem;
    margin: 0.2rem 0;
    color: var(--color-evato-amber-bright);
    text-shadow: 0 2px 8px rgba(0, 0, 0, 0.85);
  }
  @media (max-width: 720px) {
    .page-hero { aspect-ratio: 16 / 10; }
    .page-hero-overlay { padding: 1.2rem; }
    .page-hero-overlay h1 { font-size: 1.6rem; }
  }
</style>
