---
interface Props {
  size?: number;
  glow?: boolean;
}
const { size = 420, glow = true } = Astro.props;
// Aspect ratio bumped (0.28 → 0.45) to make room for the skull silhouette
// crowning the wordmark.
const height = Math.round(size * 0.45);
---
<div class="evato-logo" style={`--logo-size:${size}px;--logo-h:${height}px;`}>
  <svg
    viewBox="0 0 600 270"
    width={size}
    height={height}
    role="img"
    aria-label="Evatosorus"
    class:list={["evato-logo-svg", { glow }]}
  >
    <defs>
      <linearGradient id="amber-grad" x1="0%" y1="0%" x2="100%" y2="100%">
        <stop offset="0%"  stop-color="#ffc879" />
        <stop offset="55%" stop-color="#d4a55e" />
        <stop offset="100%" stop-color="#a87b3c" />
      </linearGradient>
      <filter id="amber-glow" x="-20%" y="-20%" width="140%" height="140%">
        <feGaussianBlur stdDeviation="2.4" result="b1" />
        <feMerge>
          <feMergeNode in="b1" />
          <feMergeNode in="SourceGraphic" />
        </feMerge>
      </filter>
    </defs>

    <!--
      Crâne T-Rex stylisé en line-art ambre, posé au-dessus du wordmark.
      Vue de profil gauche → droite : museau allongé, mâchoire avec
      dents, orbite oculaire creuse, fenêtre antéorbitaire. Pas une
      reconstitution scientifique exacte — un glyphe identitaire.
    -->
    <g
      transform="translate(300 70)"
      stroke="url(#amber-grad)"
      stroke-width="2.2"
      stroke-linecap="round"
      stroke-linejoin="round"
      fill="none"
      filter="url(#amber-glow)"
    >
      <!-- Outline crâne (vue profil) -->
      <path d="M -90 0 L -75 -22 L -45 -32 L -10 -36 L 30 -32 L 60 -24 L 80 -10 L 88 6 L 84 18 L 60 22 L 30 24 L -10 26 L -45 26 L -75 22 L -90 12 Z" />
      <!-- Fenêtre antéorbitaire (devant l'œil) -->
      <ellipse cx="-25" cy="-8" rx="12" ry="6" fill="#0d0a06" stroke="url(#amber-grad)" stroke-width="1.6" />
      <!-- Orbite oculaire -->
      <circle cx="20" cy="-12" r="5" fill="#ffc879" stroke="none" opacity="0.9" />
      <circle cx="20" cy="-12" r="8" fill="none" stroke-width="1.6" />
      <!-- Crête sourcilière (ridge above eye) -->
      <path d="M 8 -22 Q 22 -28 38 -22" stroke-width="1.4" />
      <!-- Narine -->
      <ellipse cx="-78" cy="-6" rx="4" ry="2.5" fill="#0d0a06" stroke-width="1.2" />
      <!-- Dents de la mâchoire supérieure (5 dents stylisées) -->
      <g stroke-width="1.4" fill="#d4a55e">
        <polygon points="-80,12 -76,22 -72,12" />
        <polygon points="-65,14 -60,26 -55,14" />
        <polygon points="-45,16 -40,28 -35,16" />
        <polygon points="-20,18 -15,28 -10,18" />
        <polygon points="5,18 10,26 15,18" />
      </g>
      <!-- Petite ligne de tension / cheek bone -->
      <path d="M 35 0 L 60 8" stroke-width="1.2" opacity="0.7" />
    </g>

    <text
      x="300" y="200"
      text-anchor="middle"
      font-family="Cinzel, serif"
      font-weight="700"
      font-size="68"
      letter-spacing="6"
      fill="url(#amber-grad)"
      filter="url(#amber-glow)"
    >EVATOSORUS</text>

    <!-- skeletal underline : a stylized vertebra row -->
    <g transform="translate(165 230)" stroke="#d4a55e" stroke-width="1.4" fill="none" opacity="0.85">
      <line x1="0" y1="6" x2="270" y2="6" />
      <circle cx="0" cy="6" r="3.5" fill="#d4a55e" />
      <circle cx="270" cy="6" r="3.5" fill="#d4a55e" />
      {Array.from({length: 9}).map((_, i) => (
        <rect x={28 + i * 26} y="2" width="8" height="8" rx="1.5" fill="#d4a55e" opacity={0.6 + (i % 3) * 0.15} />
      ))}
    </g>

    <text
      x="300" y="258"
      text-anchor="middle"
      font-family="Crimson Text, serif"
      font-style="italic"
      font-size="14"
      letter-spacing="3"
      fill="#b8a78f"
    >codex mésozoïque</text>
  </svg>
</div>

<style>
  .evato-logo {
    width: var(--logo-size);
    max-width: 100%;
    height: var(--logo-h);
    display: inline-block;
  }
  .evato-logo-svg {
    display: block;
    width: 100%;
    height: 100%;
  }
  .evato-logo-svg.glow {
    animation: amber-breathe 6s ease-in-out infinite;
  }
  @keyframes amber-breathe {
    0%, 100% { filter: drop-shadow(0 0 14px rgba(212, 165, 94, 0.35)); }
    50%      { filter: drop-shadow(0 0 28px rgba(255, 200, 121, 0.55)); }
  }
  @media (prefers-reduced-motion: reduce) {
    .evato-logo-svg.glow { animation: none; }
  }
</style>
