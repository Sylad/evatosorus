---
/**
 * Wordmark Evatosorus seul (skull est dans EvatoSkull séparé). Texte SVG
 * net, sans filter blur (qui dilluait la couleur précédemment).
 * Drop-shadow CSS multi-couches pour le halo néon — l'astuce pour avoir
 * un texte ULTRA net + un glow autour, sans qu'ils se mangent.
 */
interface Props {
  size?: number;
}
const { size = 460 } = Astro.props;
const height = Math.round(size * 0.22);
---
<div class="evato-logo" style={`--logo-size:${size}px;--logo-h:${height}px;`}>
  <svg
    viewBox="0 0 600 130"
    width={size}
    height={height}
    role="img"
    aria-label="Evatosorus"
    class="evato-logo-svg"
  >
    <text
      x="300" y="68"
      text-anchor="middle"
      font-family="Cinzel, serif"
      font-weight="900"
      font-size="68"
      letter-spacing="7"
      fill="#ffc879"
    >EVATOSORUS</text>

    <!-- Vertèbres skeleton ambre clair -->
    <g transform="translate(165 92)" stroke="#ffc879" stroke-width="1.6" fill="none">
      <line x1="0" y1="6" x2="270" y2="6" />
      <circle cx="0" cy="6" r="3.5" fill="#ffc879" />
      <circle cx="270" cy="6" r="3.5" fill="#ffc879" />
      {Array.from({length: 9}).map((_, i) => (
        <rect x={28 + i * 26} y="2" width="8" height="8" rx="1.5" fill="#ffc879" opacity={0.7 + (i % 3) * 0.1} />
      ))}
    </g>

    <text
      x="300" y="120"
      text-anchor="middle"
      font-family="Crimson Text, serif"
      font-style="italic"
      font-size="14"
      letter-spacing="3"
      fill="#fff5dc"
      opacity="0.92"
    >codex mésozoïque</text>
  </svg>
</div>

<style>
  .evato-logo {
    width: var(--logo-size);
    max-width: 100%;
    height: var(--logo-h);
    display: inline-block;
  }
  .evato-logo-svg {
    display: block;
    width: 100%;
    height: 100%;
    /* Drop-shadow CSS multi-couches : halo + ombre dure. Pas de filter SVG
       qui dilue les lettres comme une mauvaise photocopie. */
    filter:
      drop-shadow(0 0 22px rgba(255, 200, 121, 0.55))
      drop-shadow(0 0 8px rgba(255, 200, 121, 0.45))
      drop-shadow(0 1px 2px rgba(0, 0, 0, 0.95));
    animation: logo-pulse 6s ease-in-out infinite;
  }
  @keyframes logo-pulse {
    0%, 100% { filter:
      drop-shadow(0 0 18px rgba(255, 200, 121, 0.45))
      drop-shadow(0 0 6px rgba(255, 200, 121, 0.35))
      drop-shadow(0 1px 2px rgba(0, 0, 0, 0.95)); }
    50% { filter:
      drop-shadow(0 0 28px rgba(255, 200, 121, 0.7))
      drop-shadow(0 0 12px rgba(255, 200, 121, 0.55))
      drop-shadow(0 1px 2px rgba(0, 0, 0, 0.95)); }
  }
  @media (prefers-reduced-motion: reduce) {
    .evato-logo-svg { animation: none; }
  }
</style>
