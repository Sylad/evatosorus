---
/**
 * Crâne T-Rex outline jaune avec boule de lumière qui suit le contour.
 * Réutilisable dans la sidebar des pages internes (CodexLayout) et autres
 * endroits où l'on veut juste l'icône sans le wordmark complet.
 */
interface Props {
  size?: number;
  duration?: number;
}
const { size = 64, duration = 8 } = Astro.props;
const seed = Math.random().toString(36).slice(2, 8);
---
<svg
  viewBox="-100 -42 200 60"
  width={size}
  height={Math.round(size * 0.3)}
  role="img"
  aria-label="Crâne T-Rex"
  class="evato-skull"
>
  <defs>
    <radialGradient id={`skull-orb-${seed}`}>
      <stop offset="0%"  stop-color="#ffffff" stop-opacity="1" />
      <stop offset="35%" stop-color="#fff05a" stop-opacity="0.95" />
      <stop offset="100%" stop-color="#ffea00" stop-opacity="0" />
    </radialGradient>
    <filter id={`skull-glow-${seed}`} x="-50%" y="-50%" width="200%" height="200%">
      <feGaussianBlur stdDeviation="2" result="b1" />
      <feMerge>
        <feMergeNode in="b1" />
        <feMergeNode in="SourceGraphic" />
      </feMerge>
    </filter>
    <filter id={`orb-${seed}`} x="-300%" y="-300%" width="700%" height="700%">
      <feGaussianBlur stdDeviation="3" result="b" />
      <feMerge>
        <feMergeNode in="b" />
        <feMergeNode in="SourceGraphic" />
      </feMerge>
    </filter>
    <path id={`trex-skull-${seed}`} d="
      M -85 6
      L -88 -18
      L -75 -32
      L -55 -32
      L -30 -30
      L 0 -28
      L 32 -22
      L 58 -16
      L 78 -10
      L 86 -2
      L 84 6
      L 70 8
      L 55 10
      L 38 12
      L 14 13
      L -14 14
      L -42 12
      L -65 8
      L -82 4
      Z
    "/>
  </defs>

  <g filter={`url(#skull-glow-${seed})`}>
    <use href={`#trex-skull-${seed}`}
         stroke="#ffea00" stroke-width="3" stroke-linejoin="round" stroke-linecap="round"
         fill="none" />
    <path d="M -65 -4 Q 0 4 70 0" stroke="#ffea00" stroke-width="1.8" fill="none" opacity="0.75" />
    <g fill="#ffea00">
      <polygon points="50,8 53,16 56,8" />
      <polygon points="28,10 31,19 34,10" />
      <polygon points="2,11 5,21 8,11" />
      <polygon points="-22,11 -19,20 -16,11" />
      <polygon points="-44,10 -41,18 -38,10" />
    </g>
    <circle cx="32" cy="-18" r="6" stroke="#ffea00" stroke-width="2" fill="none" />
    <circle cx="32" cy="-18" r="2.3" fill="#ffffff" />
    <path d="M 22 -27 L 44 -25" stroke="#ffea00" stroke-width="1.6" fill="none" opacity="0.85" />
    <ellipse cx="72" cy="-6" rx="3.5" ry="1.8" stroke="#ffea00" stroke-width="1.4" fill="none" />
    <ellipse cx="14" cy="-14" rx="9" ry="4" stroke="#ffea00" stroke-width="1.5" fill="none" opacity="0.7" />
  </g>

  <circle r="5.5" fill={`url(#skull-orb-${seed})`} filter={`url(#orb-${seed})`}>
    <animateMotion dur={`${duration}s`} repeatCount="indefinite">
      <mpath href={`#trex-skull-${seed}`} />
    </animateMotion>
  </circle>
  <circle r="2.5" fill="#ffffff" opacity="0.9">
    <animateMotion dur={`${duration}s`} repeatCount="indefinite">
      <mpath href={`#trex-skull-${seed}`} />
    </animateMotion>
  </circle>
</svg>

<style>
  .evato-skull { display: block; width: 100%; height: auto; }
</style>
