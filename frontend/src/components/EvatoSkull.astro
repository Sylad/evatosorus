---
/**
 * Silhouette T-Rex iconique (style Chrome offline dino game) en outline
 * jaune fluo, avec boule de lumière qui parcourt le contour. Path issu
 * de Material Design Icons (mdi:t-rex), licence Apache 2.0.
 *
 * Source : https://api.iconify.design/mdi:t-rex.svg
 */
interface Props {
  size?: number;
  duration?: number;
}
const { size = 200, duration = 8 } = Astro.props;
const seed = Math.random().toString(36).slice(2, 8);

// Path mdi:t-rex original (24x24 viewBox).
const TREX_PATH = "M13 2v1h-1v6h-1v1H9v1H8v1H7v1H5v-1H4v-1H3V9H2v6h1v1h1v1h1v1h1v4h2v-1H7v-1h1v-1h1v-1h1v1h1v3h2v-1h-1v-4h1v-1h1v-1h1v-3h1v1h1v-2h-2V9h5V8h-3V7h5V3h-1V2m-7 1h1v1h-1Z";
---
<svg
  viewBox="0 0 24 24"
  width={size}
  height={size}
  role="img"
  aria-label="Silhouette T-Rex"
  class="evato-skull"
>
  <defs>
    <radialGradient id={`skull-orb-${seed}`}>
      <stop offset="0%"  stop-color="#ffffff" stop-opacity="1" />
      <stop offset="35%" stop-color="#fff05a" stop-opacity="0.95" />
      <stop offset="100%" stop-color="#ffea00" stop-opacity="0" />
    </radialGradient>
    <filter id={`skull-glow-${seed}`} x="-30%" y="-30%" width="160%" height="160%">
      <feGaussianBlur stdDeviation="0.4" result="b1" />
      <feMerge>
        <feMergeNode in="b1" />
        <feMergeNode in="SourceGraphic" />
      </feMerge>
    </filter>
    <filter id={`orb-${seed}`} x="-300%" y="-300%" width="700%" height="700%">
      <feGaussianBlur stdDeviation="0.6" result="b" />
      <feMerge>
        <feMergeNode in="b" />
        <feMergeNode in="SourceGraphic" />
      </feMerge>
    </filter>

    <path id={`trex-path-${seed}`} d={TREX_PATH} />
  </defs>

  <use href={`#trex-path-${seed}`}
       stroke="#ffea00" stroke-width="0.55" stroke-linejoin="round" stroke-linecap="round"
       fill="rgba(255, 234, 0, 0.18)" filter={`url(#skull-glow-${seed})`} />

  <!-- Boule lumineuse + traînée qui parcourent le contour de la silhouette -->
  <circle r="0.7" fill={`url(#skull-orb-${seed})`} filter={`url(#orb-${seed})`}>
    <animateMotion dur={`${duration}s`} repeatCount="indefinite">
      <mpath href={`#trex-path-${seed}`} />
    </animateMotion>
  </circle>
  <circle r="0.32" fill="#ffffff" opacity="0.95">
    <animateMotion dur={`${duration}s`} repeatCount="indefinite">
      <mpath href={`#trex-path-${seed}`} />
    </animateMotion>
  </circle>
</svg>

<style>
  .evato-skull { display: block; }
</style>
