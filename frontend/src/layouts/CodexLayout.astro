---
import BaseLayout from './BaseLayout.astro';
import EvatoSkull from '../components/EvatoSkull.astro';

interface Props {
  title?: string;
  description?: string;
  active?: 'codex' | 'periodes' | 'carte' | 'films' | 'videos' | 'about' | 'home';
}

const { title, description, active = 'home' } = Astro.props;

const NAV: { id: NonNullable<Props['active']>; label: string; href: string }[] = [
  { id: 'home',     label: 'Accueil',         href: '/' },
  { id: 'codex',    label: 'Codex',           href: '/codex/' },
  { id: 'periodes', label: 'Voyage temporel', href: '/periodes/' },
  { id: 'carte',    label: 'Carte paléo',     href: '/carte/' },
  { id: 'films',    label: 'Films',           href: '/films/' },
  { id: 'videos',   label: 'Vidéos YouTube',  href: '/videos/' },
  { id: 'about',    label: 'À propos',        href: '/about/' },
];
---
<BaseLayout title={title} description={description}>
  <!--
    Couche atmosphère : image hero T-Rex fixe en arrière-plan (blur + opacity
    légère) pour donner du souffle visuel aux pages internes. Le voile dark
    par-dessus garantit la lisibilité de la sidebar et du contenu.
  -->
  <div class="codex-bg" aria-hidden="true"></div>
  <div class="codex-bg-veil" aria-hidden="true"></div>
  <div class="amber-ambient" aria-hidden="true"></div>

  <div class="codex-shell">
    <aside class="codex-sidebar">
      <a href="/" class="codex-brand">
        <div class="brand-skull"><EvatoSkull size={180} /></div>
        <span class="brand-name">Evatosorus</span>
        <span class="brand-sub">codex mésozoïque</span>
      </a>

      <nav class="codex-nav" aria-label="Navigation principale">
        {NAV.map((n) => (
          <a
            href={n.href}
            class:list={["codex-nav-link", { active: n.id === active }]}
          >{n.label}</a>
        ))}
      </nav>

      <div class="codex-aside-foot">
        <p class="text-xs text-evato-bone-ghost italic">
          252 → 66 Ma<br/>
          1500+ espèces, 3 ères, 1 supercontinent.
        </p>
      </div>
    </aside>

    <main class="codex-main">
      <slot />
    </main>
  </div>

  <style>
    /* Background atmosphère pleinement visible : opacity 0.78, blur 1.5px,
       l'image se lit comme une vraie scène derrière le contenu. */
    .codex-bg {
      position: fixed;
      inset: 0;
      z-index: 0;
      pointer-events: none;
      background:
        url('/hero-trex.jpg') center 25% / cover no-repeat;
      filter: blur(1.5px) saturate(1.15) brightness(0.92) contrast(1.06);
      opacity: 0.78;
      animation: codex-bg-breathe 24s ease-in-out infinite;
      transform-origin: center;
    }
    @keyframes codex-bg-breathe {
      0%, 100% { transform: scale(1.04); }
      50%      { transform: scale(1.10); }
    }
    @media (prefers-reduced-motion: reduce) {
      .codex-bg { animation: none; }
    }
    /* Voile minimaliste : laisse l'image respirer pleinement, juste assez
       de noir pour la sidebar et la lisibilité du contenu. */
    .codex-bg-veil {
      position: fixed;
      inset: 0;
      z-index: 1;
      pointer-events: none;
      background:
        radial-gradient(ellipse at 50% 35%, rgba(13, 10, 6, 0.05) 0%, rgba(13, 10, 6, 0.45) 70%, rgba(13, 10, 6, 0.7) 100%),
        linear-gradient(to bottom, rgba(13, 10, 6, 0.2) 0%, rgba(13, 10, 6, 0.55) 100%);
    }
    .codex-shell {
      position: relative;
      z-index: 10;
      display: grid;
      grid-template-columns: 280px 1fr;
      min-height: 100vh;
    }
    @media (max-width: 900px) {
      .codex-shell { grid-template-columns: 1fr; }
    }
    .codex-sidebar {
      position: sticky;
      top: 0;
      align-self: start;
      max-height: 100vh;
      padding: 2rem 1.5rem;
      border-right: 1px solid rgba(212, 165, 94, 0.18);
      backdrop-filter: blur(6px);
      background: rgba(13, 10, 6, 0.45);
      display: flex;
      flex-direction: column;
      gap: 2rem;
    }
    @media (max-width: 900px) {
      .codex-sidebar {
        position: relative;
        max-height: none;
        border-right: 0;
        border-bottom: 1px solid rgba(212, 165, 94, 0.18);
      }
    }
    .codex-brand {
      display: block;
      text-decoration: none;
      color: inherit;
    }
    .brand-skull {
      display: block;
      width: 100%;
      max-width: 180px;
      margin-bottom: 0.4rem;
      filter: drop-shadow(0 0 6px rgba(255, 234, 0, 0.35));
    }
    .brand-name {
      display: block;
      font-family: var(--font-display);
      font-weight: 800;
      font-size: 1.7rem;
      letter-spacing: 0.08em;
      color: #fff5a0;
      text-shadow: 0 0 12px rgba(255, 234, 0, 0.45), 0 1px 3px rgba(0, 0, 0, 0.85);
      margin-top: 0.25rem;
    }
    .brand-sub {
      display: block;
      font-family: var(--font-display);
      font-size: 0.7rem;
      letter-spacing: 0.32em;
      color: var(--color-evato-bone-muted);
      text-transform: uppercase;
      margin-top: 0.15rem;
    }
    .codex-nav {
      display: flex;
      flex-direction: column;
      gap: 0.4rem;
    }
    .codex-nav-link {
      display: block;
      padding: 0.55rem 0.8rem;
      border-left: 2px solid transparent;
      font-family: var(--font-display);
      font-size: 0.85rem;
      letter-spacing: 0.18em;
      text-transform: uppercase;
      color: var(--color-evato-bone-muted);
      text-decoration: none;
      transition: color 200ms, border-color 200ms, background 200ms;
    }
    .codex-nav-link:hover {
      color: var(--color-evato-amber-bright);
      border-left-color: var(--color-evato-amber);
      background: rgba(212, 165, 94, 0.05);
    }
    .codex-nav-link.active {
      color: var(--color-evato-amber-bright);
      border-left-color: var(--color-evato-amber-bright);
      background: rgba(212, 165, 94, 0.08);
    }
    .codex-main {
      padding: 2.5rem clamp(1.25rem, 3vw, 3rem) 4rem;
      max-width: 1280px;
    }
  </style>
</BaseLayout>
